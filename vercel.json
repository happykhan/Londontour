{
  "framework": null,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/tiles/:z/:x/:y.png",
      "destination": "/api/tile?z=:z&x=:x&y=:y"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        },
        {
          "key": "Clear-Site-Data",
          "value": "\"cache\", \"storage\", \"executionContexts\""
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        },
        {
          "key": "Clear-Site-Data",
          "value": "\"cache\", \"storage\", \"executionContexts\""
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
